/**
 * VS Code Tasks Configuration
 * This file defines custom tasks for building and running Docker containers.
 *
 * Features:
 *  - Build a development Docker image.
 *  - Build and test a production Docker image (with no cache).
 *  - Start a live development server with hot reload.
 *  - Start a production server for testing.
 *
 * Usage:
 *  - Press Ctrl+Shift+B to run the default "Docker Start Dev & View" task.
 *  - Other tasks can be run manually from the VS Code task runner.
 */

{
  "version": "2.0.0",
  "tasks": [
    // Build the Development Image
    {
      // Task Development ( Just Writing Bcz It Was Giving Space Error)
      "label": "Build Dev Image",
      "type": "shell",
      "command": "docker build --target dev -t encrypted-app-dev .",
      "group": { "kind": "build", "isDefault": false },
      "detail": "STEP 1: Builds the encrypted-app-dev image."
    },

    // Robust Container Cleanup (Cross-Platform. Not Sure If It's Going To Work or Not)
    {
      "label": "Docker Cleanup Dev Container",
      "type": "shell",
      // Default for Linux/macOS (bash/zsh)
      "command": "docker rm -f encrypted-dev-container >/dev/null 2>&1 || true",
      "options": {
        "shell": { "executable": "bash" }
      },
      "windows": {
        // Windows PowerShell equivalent
        "command": "docker rm -f encrypted-dev-container 2>$null; exit 0",
        "options": {
          "shell": { "executable": "powershell" }
        }
      },
      "detail": "STEP 2: Removes the old container if it exists, ignores errors if not."
    },

    // Wait 10 Seconds Post Cleanup
    {
      "label": "Wait 10s Post Cleanup",
      "type": "shell",
      "command": "timeout /t 10 /nobreak",
      "detail": "STEP 3: Pauses 10s to ensure Docker releases the container name."
    },

    // Run the Dev Server Container
    {
      "label": "Docker Run Dev Server",
      "type": "shell",
      "command": "docker run -e HOST=0.0.0.0 -e CHOKIDAR_USEPOLLING=true -e WATCHPACK_POLLING=500 -p 3000:3000 --name encrypted-dev-container -d -v ${workspaceFolder}:/app -v /app/node_modules encrypted-app-dev",
      "detail": "STEP 4: Starts the new container with live reloading."
    },

    // Wait 5 Seconds for Server Startup
    {
      "label": "Wait 5 Seconds for Server Startup",
      "type": "shell",
      "command": "timeout /t 5 /nobreak",
      "detail": "STEP 5: Pauses 5s to allow the server inside the container to initialize."
    },

    // Open Browser
    {
      "label": "Open Browser",
      "type": "shell",
      "command": "explorer http://localhost:3000",
      "detail": "STEP 6: Opens the application in the browser."
    },

    // Composite Task (Ctrl+Shift+B)
    {
      "label": "Docker Start Dev & View (Ctrl+Shift+B)",
      "dependsOn": [
        "Build Dev Image",
        "Docker Cleanup Dev Container",
        "Wait 10s Post-Cleanup",
        "Docker Run Dev Server",
        "Wait 5 Seconds for Server Startup",
        "Open Browser"
      ],
      "dependsOrder": "sequence",   // Ensures tasks run one after another (There is Time Delay Because This is The Best Way I Found For Now To Fix The Container Error)
      "group": { "kind": "build", "isDefault": true },
      "detail": "Executes all steps sequentially: Build -> Cleanup -> Wait -> Run -> Wait -> Open Browser.",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    }
  ]
}
