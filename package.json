{
  "name": "encrypted-messaging-system",
  "version": "0.1.0",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "web-vitals": "2.1.4",
    "react-router-dom": "^6.20.0",
    "axios": "^1.5.0",
    "socket.io-client": "^4.7.2"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "dev": "npm start",
    "dev:docker": "docker run -e HOST=0.0.0.0 -e CHOKIDAR_USEPOLLING=true -e WATCHPACK_POLLING=500 -p 3000:3000 --name encrypted-dev-container -d -v \"$($PWD.Path):/app\" -v /app/node_modules encrypted-app-dev",
    "build:prod": "docker build -t encrypted-app-prod .",
    "start:prod": "docker run -p 8080:80 --name encrypted-prod-test -d encrypted-app-prod",
    "stop:prod": "docker stop encrypted-prod-test",
    "clean:dev": "docker stop encrypted-dev-container && docker rm encrypted-dev-container",
    "compose:up": "docker-compose up -d",
    "compose:down": "docker-compose down"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
